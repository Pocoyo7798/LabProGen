{
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.12",
  "include": ["src", "tests", "tools", "main.py"],
  "exclude": ["**/__pycache__", "dist", "build"],
  "typeCheckingMode": "off",
  "reportMissingImports": "warning",
